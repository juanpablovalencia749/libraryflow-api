{
  "info": {
    "name": "LibraryFlow API",
    "description": "Colección completa para el sistema de gestión de libros LibraryFlow. Incluye Autenticación, Libros, Reservas y Préstamos.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "PON_AQUI_TU_TOKEN_JWT",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Autenticación (Auth)",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Usuario de Prueba\",\n  \"email\": \"prueba@test.com\",\n  \"password\": \"secreta123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"prueba@test.com\",\n  \"password\": \"secreta123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "2. Gestión de Libros (Books)",
      "item": [
        {
          "name": "List Books (Public)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/books?page=1&limit=10&sortBy=createdAt&order=desc",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "books"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "status",
                  "value": "AVAILABLE",
                  "disabled": true
                },
                {
                  "key": "title",
                  "value": "Cien años",
                  "disabled": true
                },
                {
                  "key": "sortBy",
                  "value": "createdAt"
                },
                {
                  "key": "order",
                  "value": "desc"
                }
              ]
            }
          }
        },
        {
          "name": "Get Book by ID (Public)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/books/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "books",
                "1"
              ]
            }
          }
        },
        {
          "name": "Create Book (Auth Required)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Cien años de soledad\",\n  \"author\": \"Gabriel García Márquez\",\n  \"publicationYear\": 1967,\n  \"status\": \"AVAILABLE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/books",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "books"
              ]
            }
          }
        },
        {
          "name": "Update Book (Auth Required)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Cien años de soledad (Edición Ilustrada)\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/books/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "books",
                "1"
              ]
            }
          }
        },
        {
          "name": "Delete Book (Auth Required)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/books/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "books",
                "1"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "3. Préstamos y Reservas (Loans/Reservations)",
      "item": [
        {
          "name": "Reserve Book (Auth Required)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookId\": 1,\n  \"notes\": \"Quiero reservar este libro para mañana.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/loans/reserve",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "loans",
                "reserve"
              ]
            }
          }
        },
        {
          "name": "Loan Book (Auth Required)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookId\": 1,\n  \"notes\": \"Préstamo procesado en recepción.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/loans/loan",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "loans",
                "loan"
              ]
            }
          }
        },
        {
          "name": "Return Loaned Book (Auth Required)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/loans/return/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "loans",
                "return",
                "1"
              ]
            }
          }
        }
      ]
    }
  ]
}
